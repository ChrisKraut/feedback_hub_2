{
  "builds": [
    { 
      "src": "api/index.go", 
      "use": "@vercel/go",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.go" }
  ],
  "functions": {
    "api/index.go": {
      "maxDuration": 30
    }
  }
}


